# Vite environment variables must be prefixed with VITE_
#
# How backend switching works:
#
#   npm run dev          → uses .env.development  → http://localhost:8000
#   npm run dev:prod     → uses .env.devprod       → https://lms.steel.study
#   npm run build        → uses .env.production    → https://lms.steel.study
#
# To override locally without touching committed files, create .env.local
# (gitignored) and set VITE_API_BASE_URL there.

VITE_API_BASE_URL=https://lms.steel.study
